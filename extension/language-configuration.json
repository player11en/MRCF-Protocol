{
  "comments": {
    "blockComment": ["<!--", "-->"]
  },
  "brackets": [
    ["[", "]"],
    ["(", ")"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "{", "close": "}" }
  ],
  "indentation": {
    "increaseIndentPattern": "^#+\\s+",
    "decreaseIndentPattern": "^#+\\s+"
  }
}
