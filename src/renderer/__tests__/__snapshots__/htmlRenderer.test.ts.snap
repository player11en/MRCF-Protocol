exports[`renderHtml snapshot: full document HTML 1`] = `
"<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Test Document</title>
<meta name="description" content="MRCF: Test Document">
<meta name="author" content="Test Author">
<style>
/* ─── KDOC Theme — Mobile-first, 3 breakpoints ───────────────── */

/* ── Variables ── */
:root {
  --kdoc-font-body: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  --kdoc-font-mono: 'SF Mono', 'Fira Code', 'Consolas', 'Monaco', monospace;
  --kdoc-color-bg: #ffffff;
  --kdoc-color-surface: #f9fafb;
  --kdoc-color-text: #111827;
  --kdoc-color-text-muted: #6b7280;
  --kdoc-color-border: #e5e7eb;
  --kdoc-color-link: #2563eb;
  --kdoc-color-code-bg: #f3f4f6;
  --kdoc-color-vision: #6366f1;
  --kdoc-color-context: #8b5cf6;
  --kdoc-color-structure: #0891b2;
  --kdoc-color-plan: #059669;
  --kdoc-color-tasks: #d97706;
  --kdoc-color-custom: #9ca3af;
  --kdoc-sidebar-width: 248px;
  --kdoc-content-max: 780px;
  --kdoc-radius: 8px;
  --kdoc-spacing: 1.5rem;
}

/* Dark mode */
@media (prefers-color-scheme: dark) {
  :root {
    --kdoc-color-bg: #0d1117;
    --kdoc-color-surface: #161b22;
    --kdoc-color-text: #e6edf3;
    --kdoc-color-text-muted: #8b949e;
    --kdoc-color-border: #30363d;
    --kdoc-color-link: #58a6ff;
    --kdoc-color-code-bg: #1c2128;
    --kdoc-color-vision: #818cf8;
    --kdoc-color-context: #a78bfa;
    --kdoc-color-structure: #22d3ee;
    --kdoc-color-plan: #34d399;
    --kdoc-color-tasks: #fbbf24;
  }
}

/* ── Reset ── */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
  font-family: var(--kdoc-font-body);
  color: var(--kdoc-color-text);
  background: var(--kdoc-color-bg);
  line-height: 1.7;
  font-size: 16px;
  -webkit-text-size-adjust: 100%;
}

/* ── Layout ── */

/* Mobile & tablet: single column */
.kdoc-layout {
  max-width: calc(var(--kdoc-content-max) + 2 * var(--kdoc-spacing));
  margin: 0 auto;
  padding: 1.25rem var(--kdoc-spacing);
}

.kdoc-sidebar { display: none; }

/* Desktop (≥1024px): sidebar + content side-by-side */
@media (min-width: 1024px) {
  .kdoc-layout {
    display: grid;
    grid-template-columns: var(--kdoc-sidebar-width) 1fr;
    grid-template-rows: auto 1fr;
    gap: 0 2.5rem;
    max-width: calc(var(--kdoc-sidebar-width) + var(--kdoc-content-max) + 4rem + 2.5rem);
    padding: 2rem 2.5rem;
    align-items: start;
  }

  /* Header spans full width */
  .kdoc-layout > header { grid-column: 1 / -1; }
  .kdoc-layout > .kdoc-warning { grid-column: 1 / -1; }

  /* Sidebar: sticky nav */
  .kdoc-sidebar {
    display: block;
    grid-column: 1;
    position: sticky;
    top: 1.5rem;
    max-height: calc(100vh - 3rem);
    overflow-y: auto;
    padding-right: 0.5rem;
    /* custom scrollbar */
    scrollbar-width: thin;
    scrollbar-color: var(--kdoc-color-border) transparent;
  }

  /* Main content */
  .kdoc-main { grid-column: 2; min-width: 0; }

  /* Inline TOC (compact, used inside sidebar on desktop) */
  .kdoc-toc-inline { display: none; }
}

/* ── Metadata Header ── */
.kdoc-header {
  border-bottom: 2px solid var(--kdoc-color-border);
  padding-bottom: 1.25rem;
  margin-bottom: 1.75rem;
}

.kdoc-header h1 {
  font-size: clamp(1.5rem, 4vw, 2.2rem);
  font-weight: 700;
  margin-bottom: 0.5rem;
  letter-spacing: -0.02em;
  line-height: 1.2;
}

.kdoc-header-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.6rem 1rem;
  color: var(--kdoc-color-text-muted);
  font-size: 0.875rem;
  margin-top: 0.4rem;
}

.kdoc-tag {
  display: inline-block;
  background: var(--kdoc-color-code-bg);
  color: var(--kdoc-color-text-muted);
  padding: 0.15rem 0.55rem;
  border-radius: 12px;
  font-size: 0.78rem;
  border: 1px solid var(--kdoc-color-border);
}

.kdoc-status-badge {
  display: inline-block;
  padding: 0.15rem 0.6rem;
  border-radius: 12px;
  font-size: 0.78rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}
.kdoc-status-draft   { background: #fef9c3; color: #713f12; }
.kdoc-status-active  { background: #dcfce7; color: #14532d; }
.kdoc-status-archived{ background: var(--kdoc-color-code-bg); color: var(--kdoc-color-text-muted); }
@media (prefers-color-scheme: dark) {
  .kdoc-status-draft   { background: #422006; color: #fef08a; }
  .kdoc-status-active  { background: #052e16; color: #86efac; }
}

/* ── Sidebar Nav (desktop sticky TOC) ── */
.kdoc-sidebar-nav {
  background: var(--kdoc-color-surface);
  border: 1px solid var(--kdoc-color-border);
  border-radius: var(--kdoc-radius);
  padding: 1rem 1.1rem;
}

.kdoc-sidebar-nav h2 {
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--kdoc-color-text-muted);
  margin-bottom: 0.75rem;
  font-weight: 600;
}

.kdoc-sidebar-nav ul { list-style: none; }
.kdoc-sidebar-nav li { margin: 0; }

.kdoc-sidebar-nav a {
  display: block;
  color: var(--kdoc-color-text-muted);
  text-decoration: none;
  font-size: 0.875rem;
  padding: 0.28rem 0.4rem;
  border-radius: 4px;
  border-left: 2px solid transparent;
  transition: color 0.15s, border-color 0.15s, background 0.15s;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.kdoc-sidebar-nav a:hover {
  color: var(--kdoc-color-text);
  background: var(--kdoc-color-code-bg);
}

.kdoc-sidebar-nav .nav-sub { padding-left: 0.9rem; }
.kdoc-sidebar-nav .nav-sub a { font-size: 0.8rem; }
.kdoc-sidebar-nav .nav-sub2 { padding-left: 1.8rem; }
.kdoc-sidebar-nav .nav-sub2 a { font-size: 0.75rem; }

/* Active section highlight (set by JS if available) */
.kdoc-sidebar-nav a.active {
  color: var(--kdoc-color-link);
  border-left-color: var(--kdoc-color-link);
  font-weight: 500;
}

/* Progress bar at top of sidebar */
.kdoc-progress-bar {
  width: 100%;
  height: 3px;
  background: var(--kdoc-color-border);
  border-radius: 2px;
  margin-bottom: 1rem;
  overflow: hidden;
}
.kdoc-progress-fill {
  height: 100%;
  background: var(--kdoc-color-plan);
  border-radius: 2px;
  transition: width 0.3s;
}

/* ── Inline TOC (mobile / tablet) ── */
.kdoc-toc-inline {
  background: var(--kdoc-color-surface);
  border: 1px solid var(--kdoc-color-border);
  border-radius: var(--kdoc-radius);
  padding: 1rem 1.25rem;
  margin-bottom: 2rem;
}

.kdoc-toc-inline h2 {
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--kdoc-color-text-muted);
  margin-bottom: 0.7rem;
  font-weight: 600;
}

.kdoc-toc-inline ul { list-style: none; }
.kdoc-toc-inline li { margin: 0.25rem 0; }

.kdoc-toc-inline a {
  color: var(--kdoc-color-link);
  text-decoration: none;
  font-size: 0.9rem;
}
.kdoc-toc-inline a:hover { text-decoration: underline; }
.kdoc-toc-inline .toc-level-1 { padding-left: 1rem; }
.kdoc-toc-inline .toc-level-2 { padding-left: 2rem; font-size: 0.83rem; }

/* ── Sections ── */
.kdoc-section {
  margin-bottom: 2.5rem;
  padding-left: 0.9rem;
  border-left: 4px solid var(--kdoc-color-custom);
  scroll-margin-top: 1.5rem;
}

.kdoc-section h2 {
  font-size: clamp(1.2rem, 3vw, 1.6rem);
  font-weight: 700;
  margin-bottom: 1rem;
}

.kdoc-section-vision    { border-left-color: var(--kdoc-color-vision); }
.kdoc-section-context   { border-left-color: var(--kdoc-color-context); }
.kdoc-section-structure { border-left-color: var(--kdoc-color-structure); }
.kdoc-section-plan      { border-left-color: var(--kdoc-color-plan); }
.kdoc-section-tasks     { border-left-color: var(--kdoc-color-tasks); }

.kdoc-section-vision h2    { color: var(--kdoc-color-vision); }
.kdoc-section-context h2   { color: var(--kdoc-color-context); }
.kdoc-section-structure h2 { color: var(--kdoc-color-structure); }
.kdoc-section-plan h2      { color: var(--kdoc-color-plan); }
.kdoc-section-tasks h2     { color: var(--kdoc-color-tasks); }

/* ── Content ── */
.kdoc-section p { margin-bottom: 0.8rem; }

.kdoc-section h3 {
  font-size: clamp(1rem, 2.5vw, 1.25rem);
  margin: 1.5rem 0 0.5rem;
  scroll-margin-top: 1.5rem;
}

.kdoc-section h4 {
  font-size: 1rem;
  margin: 1.1rem 0 0.4rem;
  color: var(--kdoc-color-text-muted);
}

.kdoc-section ul,
.kdoc-section ol { margin: 0.7rem 0; padding-left: 1.6rem; }
.kdoc-section li { margin-bottom: 0.25rem; }

/* ── Code ── */
.kdoc-section code {
  font-family: var(--kdoc-font-mono);
  background: var(--kdoc-color-code-bg);
  padding: 0.12rem 0.35rem;
  border-radius: 4px;
  font-size: 0.875em;
  word-break: break-word;
}

.kdoc-section pre {
  background: var(--kdoc-color-code-bg);
  border: 1px solid var(--kdoc-color-border);
  border-radius: var(--kdoc-radius);
  padding: 1rem 1.1rem;
  overflow-x: auto;
  margin: 1rem 0;
  -webkit-overflow-scrolling: touch;
}

.kdoc-section pre code {
  background: none;
  padding: 0;
  font-size: 0.82rem;
  line-height: 1.55;
  word-break: normal;
}

/* ── Tables — scrollable on small screens ── */
.kdoc-table-wrapper {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  margin: 1rem 0;
  border-radius: var(--kdoc-radius);
  border: 1px solid var(--kdoc-color-border);
}

.kdoc-section table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.9rem;
  min-width: 360px;
}

.kdoc-section th,
.kdoc-section td {
  border-bottom: 1px solid var(--kdoc-color-border);
  padding: 0.55rem 0.8rem;
  text-align: left;
  white-space: nowrap;
}
.kdoc-section td { white-space: normal; }

.kdoc-section th {
  background: var(--kdoc-color-surface);
  font-weight: 600;
  font-size: 0.82rem;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  color: var(--kdoc-color-text-muted);
}
.kdoc-section tr:last-child td { border-bottom: none; }
.kdoc-section tr:hover td { background: var(--kdoc-color-surface); }

/* ── Task List ── */
.kdoc-task-list { list-style: none; }

.kdoc-task {
  display: flex;
  align-items: flex-start;
  gap: 0.6rem;
  padding: 0.45rem 0;
  border-bottom: 1px solid var(--kdoc-color-border);
  line-height: 1.5;
}

.kdoc-task:last-child { border-bottom: none; }

.kdoc-task input[type="checkbox"] {
  width: 1rem;
  height: 1rem;
  accent-color: var(--kdoc-color-plan);
  flex-shrink: 0;
  margin-top: 0.2rem;
  cursor: default;
}

.kdoc-task-done {
  color: var(--kdoc-color-text-muted);
  text-decoration: line-through;
}

/* ── Blockquotes ── */
.kdoc-section blockquote {
  border-left: 3px solid var(--kdoc-color-border);
  padding-left: 1rem;
  color: var(--kdoc-color-text-muted);
  margin: 1rem 0;
  font-style: italic;
}

/* ── Images / Video / Audio ── */
.kdoc-section img,
.kdoc-section video,
.kdoc-section audio {
  max-width: 100%;
  height: auto;
  border-radius: var(--kdoc-radius);
  margin: 0.75rem 0;
  display: block;
}
.kdoc-section video {
  background: #000;
}
.kdoc-section audio {
  width: 100%;
}

.kdoc-asset-missing {
  display: inline-block;
  background: #fef3c7;
  border: 2px dashed #f59e0b;
  border-radius: var(--kdoc-radius);
  padding: 0.75rem 1.25rem;
  color: #92400e;
  font-size: 0.875rem;
  margin: 0.75rem 0;
}

/* ── Links ── */
.kdoc-section a { color: var(--kdoc-color-link); text-decoration: none; }
.kdoc-section a:hover { text-decoration: underline; }

/* ── Warnings ── */
.kdoc-warning {
  background: #fffbeb;
  border: 1px solid #fcd34d;
  border-radius: var(--kdoc-radius);
  padding: 0.75rem 1.1rem;
  margin-bottom: 1.25rem;
  color: #78350f;
  font-size: 0.9rem;
}
@media (prefers-color-scheme: dark) {
  .kdoc-warning { background: #1c1006; border-color: #92400e; color: #fcd34d; }
}

/* ── Subsections ── */
.kdoc-subsection { margin-top: 1.5rem; }
.kdoc-subsection h3 { scroll-margin-top: 1.5rem; }

/* ── Footer ── */
.kdoc-footer {
  margin-top: 3rem;
  padding-top: 1.25rem;
  border-top: 1px solid var(--kdoc-color-border);
  color: var(--kdoc-color-text-muted);
  font-size: 0.82rem;
  text-align: center;
}

/* ── Scroll-spy active indicator (progressive enhancement via inline JS) ── */
.kdoc-sidebar-nav a[data-section].active {
  color: var(--kdoc-color-link);
  border-left-color: var(--kdoc-color-link);
}

/* ─── Tablet (640px – 1023px) ─────────────────────────────────── */
@media (min-width: 640px) {
  .kdoc-layout {
    padding: 1.75rem 2rem;
  }

  .kdoc-section {
    padding-left: 1.1rem;
  }

  .kdoc-section pre {
    font-size: 0.9rem;
  }
}

/* ─── Desktop (≥1024px) ───────────────────────────────────────── */
@media (min-width: 1024px) {
  .kdoc-layout {
    display: grid;
    grid-template-columns: var(--kdoc-sidebar-width) 1fr;
    gap: 0 2.5rem;
    max-width: calc(var(--kdoc-sidebar-width) + var(--kdoc-content-max) + 2.5rem + 4rem);
    padding: 2rem 2.5rem;
    align-items: start;
  }

  .kdoc-layout > .kdoc-header  { grid-column: 1 / -1; }
  .kdoc-layout > .kdoc-warning { grid-column: 1 / -1; }
  .kdoc-layout > .kdoc-footer  { grid-column: 1 / -1; }

  .kdoc-sidebar {
    display: block;
    grid-column: 1;
    position: sticky;
    top: 1.5rem;
    max-height: calc(100vh - 3rem);
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--kdoc-color-border) transparent;
  }

  .kdoc-main {
    grid-column: 2;
    min-width: 0;
  }

  /* Hide inline TOC on desktop — sidebar replaces it */
  .kdoc-toc-inline { display: none; }
}

/* ─── Print ───────────────────────────────────────────────────── */
@media print {
  .kdoc-sidebar,
  .kdoc-toc-inline { display: none !important; }

  .kdoc-layout {
    display: block;
    max-width: 100%;
    padding: 0;
  }

  .kdoc-section {
    break-inside: avoid;
    border-left-width: 3px;
  }

  .kdoc-section h2 { break-after: avoid; }

  pre, table { break-inside: avoid; }

  a { color: inherit; text-decoration: none; }
  a[href]::after { content: " (" attr(href) ")"; font-size: 0.8em; color: #666; }
}
</style>
</head>
<body>
<div class="kdoc-layout">
<header class="kdoc-header">
<h1>Test Document</h1>
<div class="kdoc-header-meta">
<span>v1.0</span>
<span>Test Author</span>
<span>2026-03-12</span>
<span>draft</span>
</div>
<div style="margin-top: 0.5rem;">
<span class="kdoc-tag">test</span> 
<span class="kdoc-tag">docs</span> 
</div>
</header>
<aside class="kdoc-sidebar" aria-label="Document navigation">
<nav class="kdoc-sidebar-nav" aria-label="Page sections">
<div class="kdoc-progress-bar"><div class="kdoc-progress-fill" id="kdoc-progress"></div></div>
<h2>Contents</h2>
<ul>
<li><a href="#vision" data-section="vision">VISION</a>
</li>
<li><a href="#context" data-section="context">CONTEXT</a>
</li>
<li><a href="#structure" data-section="structure">STRUCTURE</a>
</li>
<li><a href="#plan" data-section="plan">PLAN</a>
</li>
<li><a href="#tasks" data-section="tasks">TASKS</a>
</li>
</ul>
</nav>
</aside>
<div class="kdoc-main">
<nav class="kdoc-toc-inline" aria-label="Table of contents">
<h2>Contents</h2>
<ul>
<li class="toc-level-0"><a href="#vision">VISION</a>
</li>
<li class="toc-level-0"><a href="#context">CONTEXT</a>
</li>
<li class="toc-level-0"><a href="#structure">STRUCTURE</a>
</li>
<li class="toc-level-0"><a href="#plan">PLAN</a>
</li>
<li class="toc-level-0"><a href="#tasks">TASKS</a>
</li>
</ul>
</nav>
<main>
<section id="vision" class="kdoc-section kdoc-section-vision">
<h2>VISION</h2>
<div class="kdoc-section-content">
<p>Build something <strong>great</strong>.</p>
</div>
</section>
<section id="context" class="kdoc-section kdoc-section-context">
<h2>CONTEXT</h2>
<div class="kdoc-section-content">
<p>For developers.</p>
</div>
</section>
<section id="structure" class="kdoc-section kdoc-section-structure">
<h2>STRUCTURE</h2>
<div class="kdoc-section-content">
<p>Modular system.</p>
</div>
</section>
<section id="plan" class="kdoc-section kdoc-section-plan">
<h2>PLAN</h2>
<div class="kdoc-section-content">
<p>Phase 1: Build.</p>
</div>
</section>
<section id="tasks" class="kdoc-section kdoc-section-tasks">
<h2>TASKS</h2>
</section>
</main>
</div>
<footer class="kdoc-footer">
  <p>Generated from MRCF v1.0 — Test Document</p>
</footer>
</div>
<script>
(function() {
  var links = document.querySelectorAll('.kdoc-sidebar-nav a[data-section]');
  var sections = Array.from(links).map(function(a) {
    return document.getElementById(a.getAttribute('data-section'));
  }).filter(Boolean);
  var progress = document.getElementById('kdoc-progress');

  function update() {
    var scrollY = window.scrollY;
    var docH = document.documentElement.scrollHeight - window.innerHeight;
    if (progress && docH > 0) {
      progress.style.width = Math.min(100, (scrollY / docH) * 100).toFixed(1) + '%';
    }
    var active = sections[0];
    for (var i = 0; i < sections.length; i++) {
      if (sections[i].getBoundingClientRect().top <= 80) active = sections[i];
    }
    links.forEach(function(a) {
      a.classList.toggle('active', a.getAttribute('data-section') === (active && active.id));
    });
  }

  window.addEventListener('scroll', update, { passive: true });
  update();
})();
</script>
</body>
</html>"
`;
